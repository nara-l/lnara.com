---
import { type CollectionEntry, getCollection } from "astro:content";
import PostDetails from "@/layouts/PostDetails.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getNotePath, isNote } from "@/utils/entryPaths";

export interface Props {
  post: CollectionEntry<"blog">;
}

export async function getStaticPaths() {
  const notes = await getCollection(
    "blog",
    entry => !entry.data.draft && isNote(entry)
  );
  const noteResult = notes.map(note => ({
    params: { slug: getNotePath(note.id, note.filePath, false) },
    props: { post: note },
  }));

  return noteResult;
}

const { post } = Astro.props;

const posts = await getCollection("blog");
const sortedNotes = getSortedPosts(posts).filter(note => isNote(note));
---

<PostDetails
  post={post}
  posts={sortedNotes}
  pathBase="/notes"
  entryLabel="Note"
/>
