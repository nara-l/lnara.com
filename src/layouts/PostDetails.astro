---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  pathBase?: "/posts" | "/notes";
  entryLabel?: "Post" | "Note";
}

const { post, posts, pathBase = "/posts", entryLabel = "Post" } = Astro.props;
const entryPath = (id: string, filePath: string | undefined) =>
  getPath(id, filePath, true, pathBase);

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);
const { audio } = post.data;

const stripTrailingIndexSection = (body: string) =>
  body.replace(/\n##\s+Index\s*\n[\s\S]*$/i, "").trim();

const cleanHeadingText = (value: string) =>
  value
    .replace(/\[(.*?)\]\([^)]+\)/g, "$1")
    .replace(/[`*_~]/g, "")
    .trim();

const getTocItems = (body: string) => {
  const seen = new Map<string, number>();
  const items: { id: string; text: string }[] = [];
  const h2Pattern = /^##\s+(?!#)(.+)$/gm;
  let match: RegExpExecArray | null;

  while ((match = h2Pattern.exec(body)) !== null) {
    const text = cleanHeadingText(match[1]);
    if (!text || text.toLowerCase() === "index") continue;

    const baseId = slugifyStr(text) || `section-${items.length + 1}`;
    const count = seen.get(baseId) ?? 0;
    seen.set(baseId, count + 1);

    items.push({
      id: count === 0 ? baseId : `${baseId}-${count + 1}`,
      text,
    });
  }

  return items;
};

const articleBody = stripTrailingIndexSection(post.body ?? "");
const tocItems = getTocItems(articleBody);
const isNoteEntry = entryLabel === "Note";

const bodyText = articleBody
  .replace(/<[^>]+>/g, " ")
  .replace(/\[(.*?)\]\([^)]+\)/g, "$1")
  .replace(/[#_*`>~\-]/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const wordCount = bodyText ? bodyText.split(" ").length : 0;
const readMinutes = wordCount ? Math.ceil(wordCount / 220) : 0;
const listenMinutes = wordCount ? Math.ceil(wordCount / 150) : 0;
const showNoteToc = isNoteEntry && wordCount > 1500 && tocItems.length >= 3;

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${entryPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
  sectionName: entryLabel === "Note" ? "Notes" : "Posts",
  sectionPath: pathBase,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={[
      "mx-auto w-full max-w-app px-5 pb-12 sm:px-4",
      { "mt-8": !SITE.showBackButton },
    ]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title)}
      class="inline-block text-2xl font-semibold text-[#1a1a1a] sm:text-3xl dark:text-[#e8e8e8]"
    >
      {title}
    </h1>
    <div class="my-2 flex flex-wrap items-center gap-x-2 gap-y-1 font-mono">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      {
        wordCount > 0 && (
          <>
            <span aria-hidden="true" class="opacity-60">
              |
            </span>
            <span class="text-sm opacity-80 sm:text-base">
              {wordCount} words
            </span>
            <span aria-hidden="true" class="opacity-60">
              |
            </span>
            <span class="text-sm opacity-80 sm:text-base">
              {readMinutes} min read
            </span>
            {audio && (
              <>
                <span aria-hidden="true" class="opacity-60">
                  |
                </span>
                <span class="text-sm opacity-80 sm:text-base">
                  {listenMinutes} min listen
                </span>
              </>
            )}
          </>
        )
      }
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    {
      audio && (
        <div class="mt-4">
          <audio id="audio-player" class="w-full" controls preload="none">
            <source src={audio} type="audio/mpeg" />
            Your browser does not support the audio element.
          </audio>
          <div class="mt-2 flex gap-2">
            <span class="text-sm opacity-80">Speed:</span>
            <button
              class="playback-speed text-sm opacity-60 transition-opacity hover:opacity-100"
              data-speed="1"
            >
              1x
            </button>
            <button
              class="playback-speed text-sm opacity-60 transition-opacity hover:opacity-100"
              data-speed="1.25"
            >
              1.25x
            </button>
            <button
              class="playback-speed text-sm opacity-60 transition-opacity hover:opacity-100"
              data-speed="1.5"
            >
              1.5x
            </button>
            <button
              class="playback-speed text-sm opacity-60 transition-opacity hover:opacity-100"
              data-speed="2"
            >
              2x
            </button>
          </div>
        </div>
      )
    }
    {
      showNoteToc && (
        <>
          <nav
            class="note-toc-desktop"
            aria-label="Contents"
            data-note-toc
            data-pagefind-ignore
          >
            <div class="note-toc-title">Contents</div>
            <ol>
              {tocItems.map(item => (
                <li>
                  <a href={`#${item.id}`} data-note-toc-link>
                    {item.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>

          <details
            class="note-toc-mobile mt-6 rounded-sm border border-border px-4 py-3 font-mono text-sm"
            data-note-toc
            data-pagefind-ignore
          >
            <summary class="cursor-pointer text-xs uppercase tracking-[0.2em] text-foreground/70">
              Contents
            </summary>
            <ol class="mt-3 space-y-2">
              {tocItems.map(item => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class="text-foreground/75 underline-offset-4 hover:text-accent hover:underline"
                    data-note-toc-link
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ol>
          </details>
        </>
      )
    }
    <article
      id="article"
      class="app-prose mx-auto mt-8 max-w-[68ch] prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} />)}
    </ul>

    <BackToTopButton />

    <ShareLinks entryLabel={entryLabel === "Note" ? "note" : "post"} />

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Entry Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={entryPath(prevPost.id, prevPost.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>Previous {entryLabel}</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={entryPath(nextPost.id, nextPost.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>Next {entryLabel}</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer
    entryIndexPath={`${pathBase}/`}
    entryIndexLabel={`All ${entryLabel === "Note" ? "notes" : "posts"}`}
  />
</Layout>

<style>
  .note-toc-desktop {
    display: none;
  }

  .note-toc-mobile ol {
    list-style: decimal;
    padding-inline-start: 1.25rem;
  }

  @media (min-width: 1280px) {
    .note-toc-mobile {
      display: none;
    }

    .note-toc-desktop {
      position: fixed;
      top: 7rem;
      left: max(1rem, calc((100vw - 48rem) / 2 - 16rem));
      display: block;
      width: 9.5rem;
      max-height: calc(100vh - 9rem);
      overflow: auto;
      padding-inline-end: 1rem;
      font-family:
        ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
        "Liberation Mono", "Courier New", monospace;
      font-size: 0.72rem;
      line-height: 1.45;
    }

    .note-toc-title {
      margin-bottom: 0.75rem;
      color: color-mix(in srgb, var(--foreground) 55%, transparent);
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .note-toc-desktop ol {
      margin: 0;
      list-style: none;
      padding: 0;
    }

    .note-toc-desktop li + li {
      margin-top: 0.65rem;
    }

    .note-toc-desktop a {
      display: block;
      border-inline-start: 1px solid
        color-mix(in srgb, var(--foreground) 16%, transparent);
      color: color-mix(in srgb, var(--foreground) 58%, transparent);
      padding-inline-start: 0.65rem;
      text-decoration: none;
      transition:
        border-color 150ms ease,
        color 150ms ease;
    }

    .note-toc-desktop a:hover,
    .note-toc-desktop a:focus,
    .note-toc-desktop a[aria-current="true"] {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }

    .note-toc-desktop a:focus-visible {
      outline: 2px dashed var(--color-accent);
      outline-offset: 3px;
    }
  }
</style>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  function setupNoteToc() {
    const tocLinks = Array.from(
      document.querySelectorAll("[data-note-toc-link]")
    );
    if (tocLinks.length === 0) return;

    const tocIds = Array.from(
      new Set(
        tocLinks
          .map(link => link.getAttribute("href")?.replace(/^#/, ""))
          .filter(Boolean)
      )
    );

    const h2s = Array.from(document.querySelectorAll("#article h2"));
    h2s.forEach((heading, index) => {
      const id = tocIds[index];
      if (id) heading.id = id;
    });

    tocLinks.forEach(link => {
      link.addEventListener("click", () => {
        link.closest("details")?.removeAttribute("open");
      });
    });

    if (!("IntersectionObserver" in window)) return;

    const sectionLinks = new Map();
    tocLinks.forEach(link => {
      const id = link.getAttribute("href")?.replace(/^#/, "");
      if (!id) return;
      const links = sectionLinks.get(id) ?? [];
      links.push(link);
      sectionLinks.set(id, links);
    });

    function setCurrentSection(id) {
      tocLinks.forEach(link => link.removeAttribute("aria-current"));
      const links = sectionLinks.get(id) ?? [];
      links.forEach(link => link.setAttribute("aria-current", "true"));
    }

    const observer = new IntersectionObserver(
      entries => {
        const visible = entries
          .filter(entry => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        const current = visible[0]?.target;
        if (current?.id) setCurrentSection(current.id);
      },
      { rootMargin: "-18% 0px -70% 0px", threshold: 0 }
    );

    h2s.forEach(heading => {
      if (heading.id && sectionLinks.has(heading.id)) {
        observer.observe(heading);
      }
    });
  }
  setupNoteToc();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("#article h2, #article h3, #article h4, #article h5, #article h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );

  /* Audio playback speed controls */
  function setupAudioSpeedControls() {
    const audioPlayer = document.getElementById("audio-player");
    const speedButtons = document.querySelectorAll(".playback-speed");

    if (!audioPlayer || speedButtons.length === 0) return;

    // Set initial active state for 1x
    speedButtons[0].style.opacity = "1";
    speedButtons[0].style.fontWeight = "600";

    speedButtons.forEach(button => {
      button.addEventListener("click", () => {
        const speed = parseFloat(button.getAttribute("data-speed"));
        audioPlayer.playbackRate = speed;

        // Update active state
        speedButtons.forEach(btn => {
          btn.style.opacity = "0.6";
          btn.style.fontWeight = "400";
        });
        button.style.opacity = "1";
        button.style.fontWeight = "600";
      });
    });
  }
  setupAudioSpeedControls();
</script>
