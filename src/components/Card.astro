---
import { slugifyStr } from "@/utils/slugify";
import type { CollectionEntry } from "astro:content";
import { getEntryPath } from "@/utils/entryPaths";
import Datetime from "./Datetime.astro";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
  href?: string;
}

const { variant = "h2", data } = Astro.props;
const { title, description, pubDatetime, modDatetime, timezone } = data;
const href = Astro.props.href ?? getEntryPath(Astro.props);

const headerProps = {
  style: { viewTransitionName: slugifyStr(title) },
  class: "text-lg font-medium break-words [overflow-wrap:anywhere] hover:underline",
};
---

<li class="my-6 min-w-0">
  <a
    href={href}
    class="block max-w-full break-words text-lg font-semibold text-[#1a1a1a] underline-offset-4 [overflow-wrap:anywhere] hover:text-accent focus-visible:no-underline focus-visible:underline-offset-0 dark:text-[#e8e8e8]"
  >
    {
      variant === "h2" ? (
        <h2 {...headerProps}>{title}</h2>
      ) : (
        <h3 {...headerProps}>{title}</h3>
      )
    }
  </a>
  <Datetime {pubDatetime} {modDatetime} {timezone} />
  <p class="break-words [overflow-wrap:anywhere]">{description}</p>
</li>
